# 楽天API認証情報
# https://webservice.rakuten.co.jp/ で取得

# ============================================
# 3種類のキーの使い分け
# ============================================
# 1. Application ID（必須）
#    → API認証に使用（applicationIdパラメータ）
# 2. Affiliate ID（オプション）
#    → アフィリエイトリンク生成（affiliateIdパラメータ）
# 3. application_secret（通常不要）
#    → OAuth認証用（商品検索APIでは使用しない）

# Application ID（必須）
RAKUTEN_APPLICATION_ID=your_application_id_here

# Affiliate ID（オプション）
RAKUTEN_AFFILIATE_ID=your_affiliate_id_here
